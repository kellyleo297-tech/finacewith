{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MoneyMate AI",
  "version": "1.0.0",
  "identifier": "com.kellyleo.moneymate",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "VITE_API_URL=https://finacewith.vercel.app/api npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MoneyMate AI — 青年财务助手",
        "width": 400,
        "height": 780,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
